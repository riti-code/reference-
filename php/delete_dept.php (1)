<?php
include_once 'connection.php';

$msg = "";

// 1. PROCESS THE DELETE (If 'id' is sent via the URL)
if (isset($_GET['deptno'])) {
    $id = mysqli_real_escape_string($conn, $_GET['deptno']);

    // SQL to delete a specific record
    $sql = "DELETE FROM department WHERE dept_no = '$id'";

    if (mysqli_query($conn, $sql)) {
        $msg = "<p style='color: green;'>Department $id deleted successfully!</p>";
    } else {
        $msg = "<p style='color: red;'>Error deleting record: " . mysqli_error($conn) . "</p>";
    }
}
?>

