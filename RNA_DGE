library(edgeR)

# Set working directory
setwd("D:/rna_work")

# Read count matrix
counts <- read.table("counts.txt", header=TRUE, row.names=1, sep="\t")

# Define groups
group <- factor(c("Control","Control","Treated","Treated"))

# Create DGEList
y <- DGEList(counts=counts, group=group)

# Filter low-expression genes
keep <- rowSums(cpm(y) >= 2) >= 2
y <- y[keep, , keep.lib.sizes=FALSE]

# Normalize
y <- calcNormFactors(y)

# Estimate dispersion
y <- estimateDisp(y)

# Differential expression test
et <- exactTest(y)

# Get all results
res <- topTags(et, n=Inf)$table

# Significant genes
sig <- res[res$FDR < 0.05, ]

# Save output
write.table(sig, file="DEG_results.txt", sep="\t", quote=FALSE, row.names=TRUE)

# Optional: export full table
write.table(res, file="all_DEG_results.txt", sep="\t", quote=FALSE, row.names=TRUE)
